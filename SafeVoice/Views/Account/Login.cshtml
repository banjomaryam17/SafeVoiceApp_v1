@model LoginViewModel

@{
    ViewData["Title"] = "Login - SafeVoice";
}

<style>
    body {
        background: #f0f4f8;
    }

    .login-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }

    .login-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 32px rgba(44, 90, 160, 0.12);
        width: 100%;
        max-width: 420px;
        overflow: hidden;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .login-header {
        background: linear-gradient(135deg, #1e3f7a 0%, #2c5aa0 100%);
        color: white;
        padding: 2rem 2rem 1.5rem;
        text-align: center;
    }

    .login-header .shield-icon {
        font-size: 2.5rem;
        margin-bottom: 0.5rem;
    }

    .login-header h1 {
        margin: 0 0 0.25rem;
        font-size: 1.6rem;
        font-weight: 600;
        letter-spacing: -0.3px;
    }

    .login-header p {
        margin: 0;
        font-size: 0.85rem;
        opacity: 0.8;
    }

    .login-body {
        padding: 2rem;
    }

    .form-group {
        margin-bottom: 1.2rem;
    }

    .form-label {
        display: block;
        margin-bottom: 0.4rem;
        color: #374151;
        font-size: 0.875rem;
        font-weight: 500;
    }

    .form-control {
        width: 100%;
        padding: 11px 14px;
        border: 1.5px solid #e5e7eb;
        border-radius: 8px;
        font-size: 0.95rem;
        transition: border-color 0.2s, box-shadow 0.2s;
        box-sizing: border-box;
        color: #111827;
    }

    .form-control:focus {
        outline: none;
        border-color: #2c5aa0;
        box-shadow: 0 0 0 3px rgba(44, 90, 160, 0.1);
    }

    .form-check {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1.2rem;
        font-size: 0.875rem;
        color: #6b7280;
    }

    .btn-login {
        background: linear-gradient(135deg, #2c5aa0 0%, #1e3f7a 100%);
        color: white;
        border: none;
        padding: 12px;
        font-size: 0.95rem;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
        width: 100%;
        transition: opacity 0.2s, transform 0.1s;
        letter-spacing: 0.3px;
    }

    .btn-login:hover {
        opacity: 0.92;
        transform: translateY(-1px);
    }

    .divider {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin: 1.5rem 0;
        color: #9ca3af;
        font-size: 0.8rem;
    }

    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #e5e7eb;
    }

    .social-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .btn-social {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        width: 100%;
        padding: 11px;
        border-radius: 8px;
        font-size: 0.9rem;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.2s, transform 0.1s;
        border: none;
    }

    .btn-social:hover {
        transform: translateY(-1px);
    }

    .btn-google {
        background: white;
        border: 1.5px solid #e5e7eb !important;
        color: #374151;
    }

    .btn-google:hover {
        background: #f9fafb;
    }

    .btn-github {
        background-color: #24292e;
        color: #fff;
    }

    .btn-github:hover {
        background-color: #3a3f44;
    }

    .register-link {
        text-align: center;
        margin-top: 1.5rem;
        padding-top: 1.2rem;
        border-top: 1px solid #f3f4f6;
        font-size: 0.875rem;
        color: #6b7280;
    }

    .register-link a {
        color: #2c5aa0;
        text-decoration: none;
        font-weight: 500;
    }

    .register-link a:hover {
        text-decoration: underline;
    }

    .text-danger {
        color: #dc2626;
        font-size: 0.8rem;
        margin-top: 0.25rem;
        display: block;
    }
</style>

<div class="login-wrapper">
    <div class="login-card">
        <div class="login-header">
            <div class="shield-icon">🛡️</div>
            <h1>SafeVoice</h1>
            <p>Secure access to child safety platform</p>
        </div>

        <div class="login-body">
            <form asp-action="Login" method="post">
                <div asp-validation-summary="All" class="text-danger" style="margin-bottom:1rem;"></div>

                <div class="form-group">
                    <label asp-for="Username" class="form-label">Username</label>
                    <input asp-for="Username" class="form-control" placeholder="Enter your username" />
                    <span asp-validation-for="Username" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Password" class="form-label">Password</label>
                    <input asp-for="Password" type="password" class="form-control" placeholder="Enter your password" />
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <div class="form-check">
                    <input asp-for="RememberMe" type="checkbox" />
                    <label asp-for="RememberMe">Remember me</label>
                </div>

                <button type="submit" class="btn-login">Sign In</button>
                <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
            </form>

            <div class="divider">or continue with</div>

            <div class="social-buttons">
                <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                    <input type="hidden" name="provider" value="Google" />
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <button type="submit" class="btn-social btn-google">
                        <svg width="18" height="18" viewBox="0 0 24 24">
                            <path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                            <path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                            <path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                            <path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                        </svg>
                        Continue with Google
                    </button>
                </form>

                <form asp-controller="Account" asp-action="ExternalLogin" method="post">
                    <input type="hidden" name="provider" value="GitHub" />
                    <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />
                    <button type="submit" class="btn-social btn-github">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                        </svg>
                        Continue with GitHub
                    </button>
                </form>
            </div>

            <div class="register-link">
                Don't have an account? <a asp-action="Register">Register here</a>
            </div>
        </div>
    </div>
</div>