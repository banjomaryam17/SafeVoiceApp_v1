@{
    ViewData["Title"] = "Support SafeVoice";
}

<style>
    .donation-container {
        max-width: 600px;
        margin: 4rem auto;
        padding: 2rem;
        font-family: 'Segoe UI', sans-serif;
    }
    .donation-header {
        text-align: center;
        margin-bottom: 2rem;
    }
    .donation-header h1 {
        color: #1a3557;
        font-size: 2rem;
        margin-bottom: 0.5rem;
    }
    .donation-header p {
        color: #6b7a99;
        font-size: 1rem;
        line-height: 1.6;
    }
    .amount-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
        margin-bottom: 1.5rem;
    }
    .amount-btn {
        padding: 1rem;
        border: 2px solid #dce8f5;
        border-radius: 10px;
        background: white;
        font-size: 1.1rem;
        font-weight: 600;
        color: #1a3557;
        cursor: pointer;
        transition: all 0.2s;
        text-align: center;
    }
    .amount-btn:hover, .amount-btn.selected {
        border-color: #2c5aa0;
        background: #e8f1fb;
    }
    .donate-submit {
        width: 100%;
        padding: 1rem;
        background: linear-gradient(135deg, #2c5aa0, #1a3557);
        color: white;
        border: none;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
        margin-top: 1rem;
    }
    .donate-submit:hover { opacity: 0.9; }
    .secure-badge {
        text-align: center;
        margin-top: 1rem;
        color: #6b7a99;
        font-size: 0.8rem;
    }
</style>

<div class="donation-container">
    <div class="donation-header">
        <div style="font-size: 3rem; margin-bottom: 1rem;">💛</div>
        <h1>Support SafeVoice</h1>
        <p>Your donation helps us keep this platform running and protect children across Ireland. Every euro makes a difference.</p>
    </div>

    <form asp-action="CreateCheckoutSession" method="post">
        <p style="font-weight: 600; color: #1a3557; margin-bottom: 1rem;">Choose an amount:</p>
        <div class="amount-grid">
            <button type="submit" name="amount" value="5" class="amount-btn">€5</button>
            <button type="submit" name="amount" value="10" class="amount-btn">€10</button>
            <button type="submit" name="amount" value="20" class="amount-btn">€20</button>
            <button type="submit" name="amount" value="50" class="amount-btn">€50</button>
            <button type="submit" name="amount" value="100" class="amount-btn">€100</button>
            <button type="submit" name="amount" value="5" class="amount-btn" style="font-size:0.85rem;">Custom</button>
        </div>
        <p style="font-size: 0.8rem; color: #6b7a99; margin-top: 0.5rem;">You'll be redirected to Stripe's secure checkout.</p>
    </form>

    <div class="secure-badge">🔒 Payments secured by Stripe</div>
</div>