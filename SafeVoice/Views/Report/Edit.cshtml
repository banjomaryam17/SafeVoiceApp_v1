@model SafeVoice.Models.Report

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>Report</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-group">
                <label asp-for="Description" class="control-label"></label>
                <input asp-for="Description" class="form-control" />
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReportingAs" class="control-label">I am reporting this for:</label>
                <select asp-for="ReportingAs" class="form-control">
                    <option value="">-- Please select --</option>
                    <option value="Myself">Myself</option>
                    <option value="SomeoneElse">Someone else</option>
                    <option value="Anonymous">Anonymous (I prefer not to say)</option>
                </select>
                <span asp-validation-for="ReportingAs" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VictimName" class="control-label"></label>
                <input asp-for="VictimName" class="form-control" />
                <span asp-validation-for="VictimName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="VictimAge" class="control-label"></label>
                <input asp-for="VictimAge" class="form-control" />
                <span asp-validation-for="VictimAge" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="RelationshipToVictim" class="control-label"></label>
                <input asp-for="RelationshipToVictim" class="form-control" />
                <span asp-validation-for="RelationshipToVictim" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReporterName" class="control-label"></label>
                <input asp-for="ReporterName" class="form-control" />
                <span asp-validation-for="ReporterName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ReporterContact" class="control-label"></label>
                <input asp-for="ReporterContact" class="form-control" />
                <span asp-validation-for="ReporterContact" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Location" class="control-label"></label>
                <input asp-for="Location" class="form-control" />
                <span asp-validation-for="Location" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Latitude" class="control-label"></label>
                <input asp-for="Latitude" class="form-control" />
                <span asp-validation-for="Latitude" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Longitude" class="control-label"></label>
                <input asp-for="Longitude" class="form-control" />
                <span asp-validation-for="Longitude" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label class="control-label">Status</label>
                <input type="text" value="Pending" class="form-control" readonly />
                <input type="hidden" asp-for="Status" />
                <small class="text-muted">Only administrators can change report status</small>
            </div>
            <div class="form-group">
                <label asp-for="DateSubmitted" class="control-label"></label>
                <input asp-for="DateSubmitted" class="form-control" />
                <span asp-validation-for="DateSubmitted" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

