@model IEnumerable<SafeVoice.Models.Report>

@{
    ViewData["Title"] = "Reports Dashboard";
}

<link rel="stylesheet" href="~/css/reports.css" />

<div class="dashboard-container">
    <div class="dashboard-header">
        <h1>SafeVoice Reports Dashboard</h1>
        <p>Manage and review child safety reports</p>
    </div>

    <div class="dashboard-stats">
        <div class="stat-card">
            <div class="stat-number">@Model.Count()</div>
            <div class="stat-label">Total Reports</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.Count(r => r.Status == SafeVoice.Models.ReportStatus.Pending)</div>
            <div class="stat-label">Pending Review</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.Count(r => r.Status == SafeVoice.Models.ReportStatus.Accepted)</div>
            <div class="stat-label">Accepted</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">@Model.Count(r => r.Status == SafeVoice.Models.ReportStatus.Rejected)</div>
            <div class="stat-label">Rejected</div>
        </div>
    </div>

    <div class="actions-bar">
        <a asp-action="Create" class="create-button">
            Submit New Report
        </a>
        
        <div class="filter-section">
            <label for="statusFilter">Filter by Status:</label>
            <select id="statusFilter" class="filter-select">
                <option value="">All Reports</option>
                <option value="Pending">Pending</option>
                <option value="Accepted">Accepted</option>
                <option value="Rejected">Rejected</option>
            </select>
        </div>
    </div>

    @if (Model.Any())
    {
        <div class="reports-grid" id="reportsGrid">
            @foreach (var item in Model.OrderByDescending(r => r.DateSubmitted))
            {
                <div class="report-card" data-status="@item.Status">
                    <div class="report-header">
                        <div class="report-id">Report #@item.Id</div>
                        <div class="report-description">@Html.DisplayFor(modelItem => item.Description)</div>
                    </div>
                    
                    <div class="report-meta">
                        <div class="meta-item">
                            <span class="meta-label">Reported By</span>
                            <span class="meta-value">
                                @if (!string.IsNullOrEmpty(item.ReporterName))
                                {
                                    @item.ReporterName
                                }
                                else
                                {
                                    <em>@item.ReportingAs</em>
                                }
                            </span>
                        </div>
                        
                        <div class="meta-item">
                            <span class="meta-label">Location</span>
                            <span class="meta-value">@Html.DisplayFor(modelItem => item.Location)</span>
                        </div>
                        
                        <div class="meta-item">
                            <span class="meta-label">Date Submitted</span>
                            <span class="meta-value">@item.DateSubmitted.ToString("MMM dd, yyyy")</span>
                        </div>
                        
                        <div class="meta-item">
                            <span class="meta-label">Status</span>
                            <span class="meta-value">
                                <span class="status-badge status-@item.Status.ToString().ToLower()">
                                    @Html.DisplayFor(modelItem => item.Status)
                                </span>
                            </span>
                        </div>
                    </div>
                    
                    <div class="report-actions">
                        <a asp-action="Details" asp-route-id="@item.Id" class="action-btn btn-view">
                        View
                        </a>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="action-btn btn-edit">
                           Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="action-btn btn-delete">
                            Delete
                        </a>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <h3>No Reports Found</h3>
            <p>There are currently no reports in the system. Submit the first report to get started.</p>
        </div>
    }
</div>

<script>
// Filter functionality
document.getElementById('statusFilter').addEventListener('change', function() {
    const filterValue = this.value;
    const reportCards = document.querySelectorAll('.report-card');
    
    reportCards.forEach(card => {
        const cardStatus = card.getAttribute('data-status');
        if (filterValue === '' || cardStatus === filterValue) {
            card.style.display = 'block';
        } else {
            card.style.display = 'none';
        }
    });
});
</script>
